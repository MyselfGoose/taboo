# Server runtime
NODE_ENV=development
PORT=3000

# Set to true/false if needed. Default in code is 1 (first proxy hop).
TRUST_PROXY=1

# Comma-separated allowed browser origins for production, e.g.
# ALLOWED_ORIGINS=https://taboo.example.com,https://www.taboo.example.com
ALLOWED_ORIGINS=

# Lobby behavior
LOBBY_CODE_LENGTH=4
LOBBY_CODE_MAX_ATTEMPTS=50
LOBBY_TTL_MINUTES=120
MAX_ACTIVE_LOBBIES=20000

# Optional local HTTPS (set both values together)
# SSL_CERT_PATH=/absolute/path/to/cert.pem
# SSL_KEY_PATH=/absolute/path/to/key.pem
