# Server runtime
NODE_ENV=development
PORT=3000

# Set to true/false if needed. Default in code is 1 (first proxy hop).
TRUST_PROXY=1

# Comma-separated allowed browser origins for production, e.g.
# ALLOWED_ORIGINS=https://taboo.example.com,https://www.taboo.example.com
ALLOWED_ORIGINS=

# Lobby behavior
LOBBY_CODE_LENGTH=4
LOBBY_CODE_MAX_ATTEMPTS=50
LOBBY_TTL_MINUTES=120
MAX_ACTIVE_LOBBIES=20000

# Session storage
USE_SQLITE_SESSIONS=true
USE_SQLITE_LOBBIES=true
DATA_DIR=./data
SESSION_DB_FILE=sessions.db
SESSION_TTL_MINUTES=120

# Game defaults
DEFAULT_ROUND_COUNT=5
DEFAULT_ROUND_DURATION_SECONDS=60
